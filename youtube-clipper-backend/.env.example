# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Supabase (supabase.com)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=sua-supabase-service-key-aqui

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=sua-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=sua-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# YouTube Data API (console.cloud.google.com)
YOUTUBE_API_KEY=sua-youtube-api-key

# AI/LLM - OpenRouter (openrouter.ai)
OPENROUTER_API_KEY=sua-openrouter-api-key

# Hugging Face (opcional - huggingface.co)
HUGGINGFACE_API_KEY=sua-huggingface-key

# Email - Resend (resend.com)
RESEND_API_KEY=sua-resend-api-key

# YouTube Cookies (yt-dlp)
COOKIES_PATH=/root/Clipstrike/youtube-clipper-backend/cookies.txt
