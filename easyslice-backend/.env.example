DATABASE_URL="postgresql://easyslice:easyslice_password@localhost:5432/easyslice_db?schema=public"
REDIS_URL="redis://localhost:6379"
PORT=5000
JWT_SECRET="replace_with_a_secure_random_string"

# Google OAuth
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_CALLBACK_URL="http://localhost:5000/api/oauth/google/callback"

# Storage
S3_ACCESS_KEY="your_s3_key"
S3_SECRET_KEY="your_s3_secret"
S3_BUCKET="easyslice-clips"
S3_REGION="us-east-1"
S3_ENDPOINT="http://localhost:9000" # If using Minio for local testing

# Billing
WHOP_API_KEY="your_whop_key"
WHOP_WEBHOOK_SECRET="your_whop_webhook_secret"

# YouTube
YOUTUBE_API_KEY="your_optional_api_key_for_public_checks"
